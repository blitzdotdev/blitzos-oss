# BlitzOS environment (all optional; sensible defaults shown). Copy to .env or export in your shell.

# --- Agent backend ---
# Which agent runtime drives managed agents: 'claude' (Claude Code, default) or 'codex'.
BLITZ_AGENT_RUNTIME=claude

# --- Relay (remote agent path) ---
# The agent-socket relay an external agent connects through. Default is the public relay.
AGENT_SOCKET_RELAY=https://agentsocket.dev
# AGENT_SOCKET_APP_ID=

# --- Tool registry (optional; the agent's vetted-tool library) ---
# Point at your own deployment of registry-server/ (a Cloudflare Worker). Unset = registry disabled.
# BLITZ_TOOL_REGISTRY_URL=https://your-registry.example.workers.dev

# --- Auto-update (optional) ---
# GitHub repo the in-app updater polls for releases.
# BLITZ_UPDATE_REPO=blitzdotdev/blitzos-oss

# --- macOS code-signing (only for `npm run dist`; leave unset for an unsigned local build) ---
# APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
# APPLE_API_KEY=...           # App Store Connect API key id
# APPLE_API_KEY_PATH=...      # path to the .p8 key
# APPLE_API_ISSUER=...        # issuer id

# --- Misc ---
# CLAUDE_CONFIG_DIR=~/.claude
# CHROME_BIN=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# --- Telemetry (OFF by default; opt-in only) ---
# Session telemetry is DISABLED unless ~/.blitzos/telemetry.json exists ({url, key}).
# It captures screen frames + events, so it is strictly opt-in. To hard-disable:
# BLITZ_TELEMETRY=0
